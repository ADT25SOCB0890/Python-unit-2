class Bank:
    def __init__(self, acc_no, balance):
        self.acc_no = acc_no
        self.balance = balance

    def deposit(self, amt):
        self.balance += amt

    def withdraw(self, amt):
        self.balance -= amt

    def check_balance(self):
        print(self.balance)

b = Bank(101, 1000)
b.deposit(500)
b.withdraw(200)
b.check_balance()
